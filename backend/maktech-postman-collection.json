{
  "info": {
    "_postman_id": "maktech-api-collection",
    "name": "Maktech API",
    "description": "Complete API collection for the Maktech backend. Base URL: http://localhost:5000\n\nSetup:\n1. After calling POST /api/admin/auth/login, copy the token from the response.\n2. In the collection Variables, paste it as the value for `adminToken`.\n3. Endpoints requiring a device send `x-device-id` automatically via the collection variable `deviceId`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "PASTE_YOUR_JWT_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "deviceId",
      "value": "test-device-001",
      "type": "string"
    },
    {
      "key": "appId",
      "value": "",
      "type": "string"
    },
    {
      "key": "appSlug",
      "value": "",
      "type": "string"
    },
    {
      "key": "categorySlug",
      "value": "",
      "type": "string"
    },
    {
      "key": "reviewId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string"
